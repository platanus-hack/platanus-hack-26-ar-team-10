{
  "name": "yieldos-root",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "devDependencies": {
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "scripts": {
    "dev": "npm --prefix ./landing run dev --",
    "build": "npm --prefix ./landing run build --",
    "start": "npm --prefix ./landing run start --",
    "lint": "npm --prefix ./landing run lint --",
    "test": "npm run test:root && npm run test:plugin && npm run test:landing",
    "test:root": "node --test scripts/*.test.mjs",
    "test:plugin": "cd yieldOS/plugins/yieldos && node --test tests/*.test.js",
    "test:landing": "npm --prefix ./landing test --",
    "release:checksums": "node scripts/generate-release-checksums.mjs",
    "package:plugin": "node scripts/build-plugin-package.mjs",
    "policy:check": "node scripts/policy-check.mjs",
    "benchmark:real-repos": "node scripts/real-repo-benchmark.mjs",
    "benchmark:coverage-calibration": "node scripts/coverage-calibration-benchmark.mjs",
    "benchmark:false-positives": "node scripts/false-positive-benchmark.mjs",
    "benchmark:cost": "node scripts/cost-benchmark.mjs",
    "benchmark:models": "node scripts/model-workflow-benchmark.mjs",
    "benchmark:scanners": "node scripts/scanner-comparison-benchmark.mjs",
    "benchmark:visuals": "node scripts/benchmark-visual-dashboard.mjs",
    "evidence:verify": "node scripts/evidence-verify.mjs"
  },
  "overrides": {
    "postcss": "8.5.14"
  }
}
