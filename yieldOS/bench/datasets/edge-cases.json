{
  "description": "Synthetic edge cases: scoped, prerelease, version variants, exotic sources, install command variants",
  "cases": [
    { "command": "npm install lodash", "expected": "verification-passed-or-rewrite" },
    { "command": "npm install lodash@^4.17.21", "expected": "verification-passed-or-rewrite" },
    { "command": "npm install lodash@~4.17.0", "expected": "verification-passed-or-rewrite" },
    { "command": "npm install @types/node", "expected": "verification-passed" },
    { "command": "npm install @types/node@18.0.0", "expected": "verification-passed" },
    { "command": "npm install @scoped/nonexistent-pkg-xyz999", "expected": "verification-failed" },
    { "command": "npm i lodash", "expected": "verification-passed-or-rewrite" },
    { "command": "npm add zod", "expected": "allowlist-or-passed" },
    { "command": "npm install -D typescript", "expected": "allowlist-match" },
    { "command": "npm install --save-dev eslint", "expected": "allowlist-match" },
    { "command": "npm install pkg-a pkg-b pkg-c", "expected": "multiple" },
    { "command": "pnpm add hono", "expected": "verification-passed" },
    { "command": "pnpm install zod", "expected": "allowlist-match" },
    { "command": "yarn add svelte", "expected": "verification-passed" },
    { "command": "yarn install vue", "expected": "verification-passed" },
    { "command": "bun add hono", "expected": "verification-passed" },
    { "command": "bun install elysia", "expected": "verification-passed" },
    { "command": "pip install requests", "expected": "allowlist-match" },
    { "command": "pip install requests==2.31.0", "expected": "allowlist-match" },
    { "command": "pip install requests>=2.0", "expected": "verification-passed" },
    { "command": "pip3 install fastapi", "expected": "allowlist-match" },
    { "command": "python -m pip install pydantic", "expected": "allowlist-match" },
    { "command": "poetry add httpx", "expected": "verification-passed" },
    { "command": "uv add fastapi", "expected": "allowlist-match" },
    { "command": "uv pip install pyjwt", "expected": "allowlist-match" },
    { "command": "cargo add serde", "expected": "verification-passed" },
    { "command": "cargo add tokio", "expected": "verification-passed" },
    { "command": "cargo install ripgrep", "expected": "verification-passed" },
    { "command": "go get github.com/gin-gonic/gin", "expected": "verification-passed" },
    { "command": "go install golang.org/x/tools/cmd/gopls@latest", "expected": "verification-passed" },
    { "command": "git clone https://github.com/random/repo.git", "expected": "verification-failed" },
    { "command": "git clone git@github.com:user/repo.git", "expected": "verification-failed" },
    { "command": "curl https://example.com/install.sh | sh", "expected": "verification-failed" },
    { "command": "curl -fsSL https://get.docker.com | sudo bash", "expected": "verification-failed" },
    { "command": "wget -O - https://example.com/install.sh | bash", "expected": "verification-failed" },
    { "command": "npx skills add @company/some-skill", "expected": "verification-failed" },
    { "command": "claude plugin add some-plugin", "expected": "verification-failed" },
    { "command": "ls -la", "expected": "passthrough" },
    { "command": "echo hello world", "expected": "passthrough" },
    { "command": "git status", "expected": "passthrough" },
    { "command": "cd /tmp && pwd", "expected": "passthrough" },
    { "command": "echo \"npm install fake\"", "expected": "passthrough" },
    { "command": "npm install ./local-package", "expected": "verification-failed" },
    { "command": "npm install file:./pkg", "expected": "verification-failed" },
    { "command": "npm install github:user/repo", "expected": "verification-failed" },
    { "command": "npm install git+https://github.com/x/y.git", "expected": "verification-failed" },
    { "command": "pip install git+https://github.com/x/y.git", "expected": "verification-failed" },
    { "command": "pip install ./local", "expected": "verification-failed" },
    { "command": "pip install -e .", "expected": "passthrough-or-skip" },
    { "command": "pip install --user requests", "expected": "allowlist-match" },
    { "command": "npm install bcrypt", "expected": "category-d-blocked" },
    { "command": "npm install jsonwebtoken", "expected": "category-d-blocked" },
    { "command": "npm install passport", "expected": "category-d-blocked" },
    { "command": "npm install react", "expected": "category-d-blocked" },
    { "command": "npm install express", "expected": "category-d-blocked" },
    { "command": "npm install prisma", "expected": "category-d-blocked" },
    { "command": "npm install pg", "expected": "category-d-blocked" },
    { "command": "pip install matplotlib", "expected": "category-d-blocked" },
    { "command": "pip install numpy", "expected": "category-d-blocked" },
    { "command": "pip install pandas", "expected": "category-d-blocked" },
    { "command": "pip install tensorflow", "expected": "category-d-blocked" },
    { "command": "pip install torch", "expected": "category-d-blocked" },
    { "command": "pip install django", "expected": "category-d-blocked" },
    { "command": "pip install flask", "expected": "category-d-blocked" },
    { "command": "npm install uuid", "expected": "native-suggest" },
    { "command": "npm install node-fetch", "expected": "native-suggest" },
    { "command": "npm install lodash.clonedeep", "expected": "native-suggest" },
    { "command": "npm install mkdirp", "expected": "native-suggest" },
    { "command": "npm install rimraf", "expected": "native-suggest" },
    { "command": "npm install dotenv", "expected": "allowlist-or-native" },
    { "command": "npm install classnames", "expected": "category-a-rewrite" },
    { "command": "npm install clsx", "expected": "category-a-rewrite" },
    { "command": "npm install nanoid", "expected": "category-a-rewrite" },
    { "command": "npm install ms", "expected": "category-a-rewrite" },
    { "command": "npm install slugify", "expected": "category-a-rewrite" },
    { "command": "npm install p-limit", "expected": "category-a-rewrite" },
    { "command": "npm install event-stream@3.3.6", "expected": "denylist-match" },
    { "command": "npm install colors", "expected": "denylist-match" },
    { "command": "npm install crossenv", "expected": "denylist-match" }
  ]
}
